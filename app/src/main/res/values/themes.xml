<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.OneLineADay" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
    
    <style name="Theme.OneLineADay.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FFFBF5</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.OneLineADay</item>
    </style>
</resources>
